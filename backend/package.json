    "knex": "^3.1.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
