# ── LOCAL DEVELOPMENT ──────────────────────────────────────────────────────────
# Start the app with: npm run start:local  (opens SSH tunnel + starts server)
# First-run DB setup: open tunnel first (scripts/tunnel.sh), then: npm run migrate
#
# The tunnel maps homedev:5432 → localhost:5433.
# Port 5433 avoids conflict with any local Postgres installation.
PORT=3000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://kim:PASSWORD@localhost:5433/landlordguru_dev
#                                              ^^^^^ tunnel port — not 5432

# ── TEST SERVER (homedev ~/dev/landlordguru-test, port 3001) ───────────────────
# PORT=3001
# FRONTEND_URL=http://homedev:3001
# DATABASE_URL=postgresql://kim:PASSWORD@localhost:5432/landlordguru_test

# ── PRODUCTION (homedev ~/dev/landlordguru, port 3000) ────────────────────────
# PORT=3000
# FRONTEND_URL=http://homedev:3000
# DATABASE_URL=postgresql://kim:PASSWORD@localhost:5432/landlordguru_prod

# ── SHARED (fill in for all environments) ─────────────────────────────────────
JWT_SECRET=
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Logging
LOGGER_DEFAULT_LEVEL=error
LOGGER_STDOUT_FORMAT=json
LOGGER_STORE_IN_DB=true
