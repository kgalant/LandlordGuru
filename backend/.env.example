# Server
PORT=3000
FRONTEND_URL=http://localhost:3000

# Database
# Railway injects DATABASE_URL automatically when you add a PostgreSQL plugin.
# For local dev, create two databases and point each .env file at the right one:
#   createdb landlordguru_dev
#   createdb landlordguru_prod
DATABASE_URL=postgresql://kim@localhost:5432/landlordguru_dev

# Auth (added in Milestone 3)
JWT_SECRET=
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Logging (added in Milestone 5.5)
LOGGER_DEFAULT_LEVEL=error
LOGGER_STDOUT_FORMAT=json
LOGGER_STORE_IN_DB=true
