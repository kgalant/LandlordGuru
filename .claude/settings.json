{
  "permissions": {
    "allow": [
      "Bash(cd c:/dev/repos/LandlordGuru/backend && npm test *)",
      "Bash(npm test --prefix backend *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& (Join-Path (git rev-parse --show-toplevel) '.claude/hooks/checkpoint.ps1')\"",
            "timeout": 10,
            "statusMessage": "Restoring session state"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& (Join-Path (git rev-parse --show-toplevel) '.claude/hooks/checkpoint.ps1')\"",
            "timeout": 15,
            "statusMessage": "Saving checkpoint"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& (Join-Path (git rev-parse --show-toplevel) '.claude/hooks/checkpoint.ps1')\"",
            "timeout": 15,
            "statusMessage": "Final checkpoint"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& (Join-Path (git rev-parse --show-toplevel) '.claude/hooks/checkpoint.ps1')\"",
            "timeout": 15,
            "statusMessage": "Post-compaction checkpoint"
          }
        ]
      }
    ]
  }
}